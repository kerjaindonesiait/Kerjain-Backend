# Copy values into Vercel → Project → Settings → Environment Variables
# (Production). Do not commit a real .env.production with secrets.

FRONTEND_URL=https://kerjaindonesia.com
API_PUBLIC_URL=https://api.kerjaindonesia.com

# Optional: extra CORS origins (www is auto-added from FRONTEND_URL)
# CORS_ORIGINS=https://preview.example.vercel.app

COOKIE_SECURE=true

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.kerjaindonesia.com/auth/google/callback

RESEND_API_KEY=
EMAIL_FROM=KerjaIn <noreply@kerjaindonesia.com>

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

ADMIN_EMAILS=you@example.com
